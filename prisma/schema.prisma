generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String     @id @default(cuid())
  name           String
  contactInfo    String
  mobile         String?
  state          String
  stream         String
  streamChanges  Int        @default(0)
  createdAt      DateTime   @default(now())
  questions      Question[]
}

model Question {
  id          String    @id @default(cuid())
  userId      String
  question    String
  answer      String?
  isAnswered  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  answeredAt  DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Admin {
  id           String @id @default(cuid())
  username     String @unique
  passwordHash String
}

model College {
  id      String          @id @default(cuid())
  name    String          @unique
  state   String
  address String?
  ranking Int?
  recommendations  Recommendation[] 
  courses CollegeCourse[]
}

model Course {
  id            String          @id @default(cuid())
  title         String
  stream        String
  basicSubjects String?
  useCase       String?
  colleges      CollegeCourse[]
}

model CollegeCourse {
  id           String  @id @default(cuid())
  collegeId    String
  courseId     String
  fee          String?
  timeInvolved String?
  cutoff       String?
  remarks      String?

  college College @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([collegeId, courseId])
}
model EntranceTest {
  id           String  @id @default(cuid())
  name         String  @unique
  fullForm     String
  suitability  String
  eligibility  String
  extraRemarks String?
}

model Recommendation {
  id           String  @id @default(cuid())
  collegeId    String
  adminRank    Int
  targetStream String?
  reason       String?
  college      College @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@index([collegeId])
}

model ProfessionalCourse {
  id           String  @id @default(cuid())
  name         String  @unique
  fullForm     String
  eligibility  String
  fees         String
  duration     String
  opportunities String
  extraRemarks String?
}
